<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>EventHub Application</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- Events Servlet -->
    <servlet>
        <servlet-name>EventsServlet</servlet-name>
        <servlet-class>com.eventhub.servlets.EventsServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>EventsServlet</servlet-name>
        <url-pattern>/api/events</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.eventhub.servlets.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/api/register</url-pattern>
    </servlet-mapping>

    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/index.html</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/index.html</location>
    </error-page>

</web-app>
